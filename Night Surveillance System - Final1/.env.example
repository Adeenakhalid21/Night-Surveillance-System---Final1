# Copy to .env and fill with your values

# Email alerts configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_TO=recipient_email@example.com

# Model configuration
YOLO_WEIGHTS=runs/detect/gun_knife_hand_ft/weights/best.pt
# Night Shield fix: Dedicated weapon model path (HF repo id, URL, or local .pt path).
WEAPON_MODEL_PATH=keremberke/yolov8n-weapon-detection
# Night Shield fix: Toggle dedicated weapon model lane.
ENABLE_WEAPON_MODEL=1
HF_TOKEN=your_hf_token

# Detection configuration
DETECTION_BACKEND=hf
HF_DETECTOR_TASK=zero-shot-object-detection
HF_OBJECT_DETECTION_MODEL=IDEA-Research/grounding-dino-base
# Optional: override labels used by zero-shot model (comma separated)
# HF_ZERO_SHOT_LABELS=person,backpack,phone,knife,gun,bottle,laptop,chair,dining table
HF_ZERO_SHOT_THRESHOLD=0.30
HF_ZERO_SHOT_POST_CONF_MIN=0.30
HF_ZERO_SHOT_MAX_LABELS=28
DISABLE_DETECTION_DB=1
IMPORTANT_CLASSES=person,knife,gun,backpack
ALERT_CONF_MIN=0.6
DETECTION_CONF_MIN=0.35
DETECTION_DISPLAY_CONF_MIN=0.22
# Night Shield fix: Dedicated weapon lane confidence threshold.
WEAPON_CONF_MIN=0.50
# Night Shield fix: Require N consecutive weapon frames before alert side-effects.
WEAPON_CONFIRM_FRAMES=4

# Tracking and temporal smoothing
TRACK_IOU_THRESHOLD=0.32
TRACK_BBOX_EMA_ALPHA=0.56
TRACK_CONF_EMA_ALPHA=0.42
TRACK_MIN_HITS=2
TRACK_STALE_SEC=1.2
TRACK_CONF_DECAY_PER_SEC=0.22

# Stream tuning
DETECTION_MIN_INTERVAL_SEC=0.35
STREAM_FRAME_WIDTH=640
STREAM_FRAME_HEIGHT=480
STREAM_GRAB_SKIP=1
STREAM_JPEG_QUALITY=75
# Night Shield fix: Run dedicated weapon lane every Nth stream frame (cached between runs).
WEAPON_FRAME_SKIP=2

# Night Shield fix: Uploaded video playback controls.
# Leave VIDEO_PLAYBACK_FPS empty to use native source FPS.
VIDEO_PLAYBACK_FPS=
VIDEO_DETECT_EVERY=5
VIDEO_ENHANCE=0

# Anomaly detection configuration
ENABLE_ANOMALY_ALERTS=1
ANOMALY_CLASSES=knife,gun,weapon,fire,fight,intruder
ANOMALY_CONF_MIN=0.5
ANOMALY_MIN_BOX_AREA=1200
ANOMALY_COOLDOWN_SEC=8

# Database configuration (optional - uses SQLite by default)
# SUPABASE_DB_URL=postgresql://user:password@host:6543/postgres?sslmode=require

# Night Shield fix: Super-resolution backend selection.
# Options: realesrgan | nunif | none
SUPERRES_ENGINE=realesrgan

# Night Shield fix: Stage 1 low-light brighten controls (gamma + CLAHE).
LOWLIGHT_GAMMA=2.2
CLAHE_CLIP_LIMIT=3.0
# Night Shield fix: Stage 2 denoise toggle (runs before upscaling).
ENABLE_DENOISE=1
