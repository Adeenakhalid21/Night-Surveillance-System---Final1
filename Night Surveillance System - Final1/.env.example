# Copy to .env and fill with your values

# Email alerts configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_TO=recipient_email@example.com

# Model configuration
YOLO_WEIGHTS=runs/detect/coco_sample_pseudo/weights/best.pt

# Detection configuration
DISABLE_DETECTION_DB=1
IMPORTANT_CLASSES=person,car,motorcycle,bicycle,bus,truck
ALERT_CONF_MIN=0.6

# Anomaly detection configuration
ENABLE_ANOMALY_ALERTS=1
ANOMALY_CLASSES=person,car,motorcycle,truck,knife,gun,backpack
ANOMALY_CONF_MIN=0.5

# Database configuration (optional - uses SQLite by default)
# SUPABASE_DB_URL=postgresql://user:password@host:6543/postgres?sslmode=require
